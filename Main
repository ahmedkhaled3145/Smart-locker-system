i want to change somthing in my resume #include <Keypad.h>
#include <Servo.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);
Servo myServo;

int buzzer = 9;
int rPin = 13, bPin = 12, gPin = 11;
int led = A3;


String password = "1899";
String recoveryPassword = "0000";
String input = "";

int wrongCounter = 0;
int maxAttempts = 3;
bool systemStop = false;

char keys[4][4] = {
  { '1', '2', '3', 'A' },
  { '4', '5', '6', 'B' },
  { '7', '8', '9', 'C' },
  { '*', '0', '#', 'D' }
};

byte rowPins[4] = { 8, 7, 6, 5 };
byte colPins[4] = { 4, 3, 2, 1 };

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, 4, 4);

void resetToIdle() {
  input = "";
  lcd.backlight();
  lcd.clear();
  lcd.print("Enter pin:");
  digitalWrite(rPin, LOW);
  digitalWrite(gPin, LOW);
  digitalWrite(bPin, HIGH);
}



void setup() {

  myServo.attach(10);
  myServo.write(0);

  pinMode(buzzer, OUTPUT);
  pinMode(rPin, OUTPUT);
  pinMode(gPin, OUTPUT);
  pinMode(bPin, OUTPUT);
  pinMode(led, OUTPUT);

  lcd.init();
  lcd.backlight();
  lcd.print("Welcome ");
  delay(3000);
  resetToIdle();
}



void loop() {
  char pressedKey = keypad.getKey();

  if (pressedKey) {
    if (systemStop) {
      input += pressedKey;

      if (input == recoveryPassword) {
        systemStop = false;
        wrongCounter = 0;
        maxAttempts = 3;
        digitalWrite(led, LOW);
        lcd.backlight();
        lcd.clear();
        lcd.print("System Restored");
        delay(3000);
        resetToIdle();
      }

      if (input.length() >= 4)
        input = "";
      return;
    }

    if (pressedKey == '*') {
      if (input == password) {
        lcd.clear();
        lcd.print("VISCA BARCA");
        digitalWrite(bPin, LOW);
        digitalWrite(gPin, HIGH);
        digitalWrite(led, HIGH);
        tone(buzzer, 1500, 200);

        for (int pos = 0; pos <= 90; pos++) {
          myServo.write(pos);
          delay(15);
        }
        delay(3000);
        wrongCounter = 0;
        maxAttempts = 3;
        resetToIdle();
      } else {

        wrongCounter++;
        lcd.clear();
        lcd.print("WRONG!");
        digitalWrite(bPin, LOW);
        digitalWrite(rPin, HIGH);

        tone(buzzer, 500, 700);
        delay(1000);
      
      if (wrongCounter >= maxAttempts) {
        if (maxAttempts == 1) {
          systemStop = true;
          lcd.clear();
          lcd.noBacklight();
          digitalWrite(bPin, LOW);
          digitalWrite(rPin, LOW);
          digitalWrite(gPin, LOW);
          digitalWrite(led, LOW);
          input = "";
        } else {
          lcd.clear();
          lcd.print("Wait 5 Sec");
          for (int i = 5; i > 0; i--) {
            lcd.setCursor(0, 1);
            lcd.print("Time: ");
            lcd.print(i);
            lcd.print("  ");
            digitalWrite(rPin, HIGH);
            tone(buzzer, 1000);  
            delay(500);
            digitalWrite(rPin, LOW);
            noTone(buzzer);
            delay(500);
          }

          if (maxAttempts == 3) maxAttempts = 2;
          else if (maxAttempts == 2) maxAttempts = 1;

          wrongCounter = 0;
          resetToIdle();
        
      } }else {
        resetToIdle();
      }
    }
    input = "";
  }

  else if (pressedKey == 'C') {
    myServo.write(0);
    digitalWrite(led, LOW);
    lcd.clear();
    lcd.print("Locked");
    delay(1000);
    resetToIdle();
  }

  else if (pressedKey == 'D') {
    if (input.length() > 0) {
      input.remove(input.length() - 1);
      lcd.clear();
      lcd.print("Enter Pass:");
      lcd.setCursor(0, 1);
      for (int i = 0; i < input.length(); i++) lcd.print("*");
    }
  }

  else {
    if (input.length() < 4) {
      input += pressedKey;
      lcd.setCursor(input.length() - 1, 1);
      lcd.print("*");
    }
  }
}
} that is a project i want to put it in  
